#!/bin/bash
# Valheim server backup script
# Backs up world data and server config

set -e

BACKUP_DIR="{{ backup_directory }}"
DATA_DIR="{{ valheim.data_dir }}"
CONFIG_DIR="{{ valheim.config_dir }}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/valheim_backup_${TIMESTAMP}.tar.gz"

echo "[$(date)] Starting Valheim backup..."

# Create backup
tar -czf "${BACKUP_FILE}" -C "${DATA_DIR}" . 2>/dev/null || true
tar -czf "${BACKUP_FILE}.config" -C "${CONFIG_DIR}" . 2>/dev/null || true

echo "[$(date)] Backup created: ${BACKUP_FILE}"
echo "[$(date)] Backup size: $(du -h "${BACKUP_FILE}" | cut -f1)"

# Cleanup old backups (keep last {{ backup_retention_days }} days)
find "${BACKUP_DIR}" -name "valheim_backup_*.tar.gz" -mtime +{{ backup_retention_days }} -delete

echo "[$(date)] Backup complete"
